{
    "manifest_version": 2.0,
    "id": "zabbix-im",
    "name": "Zabbix IM",
    "author": "火星小刘",
    "url": "https://github.com/X-Mars/zabbix_modules",
    "version": "1.0.0",
    "namespace": "ZabbixIm",
    "description": "Sync departments and users from WeCom, Feishu or DingTalk to Zabbix user groups",
    "actions": {
        "im": {
            "class": "Im",
            "view": "im"
        },
        "im.sync": {
            "class": "ImSync"
        },
        "im.sync.users": {
            "class": "ImSyncUsers"
        },
        "im.preview": {
            "class": "ImPreview"
        },
        "im.settings": {
            "class": "ImSettings",
            "view": "im.settings"
        },
        "im.settings.save": {
            "class": "ImSettingsSave"
        },
        "im.settings.delete": {
            "class": "ImSettingsDelete"
        },
        "im.settings.enable": {
            "class": "ImSettingsEnable"
        }
    }
}
